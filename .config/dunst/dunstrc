[global]
    ### Display ###

    # Which monitor to show the notifications on.
    monitor = 0

    # Display notification on focused monitor. Possible modes are:
    #   mouse    — follow mouse pointer (unreliable on Wayland)
    #   keyboard — follow window with keyboard focus
    #   none     — use the `monitor` option above
    follow = keyboard

    ### Geometry ###

    # Width: single value = fixed; pair = (min, max) and window grows to fit.
    width = (0, 500)

    # Maximum height of a single notification, excluding frame.
    height = 350

    # Anchor point for positioning. Values: top-left, top-center, top-right,
    # bottom-left, bottom-center, bottom-right, left-center, right-center, center.
    origin = top-right

    # Offset from the origin, measured in pixels.
    offset = 25x25

    # Scale factor. 0 means auto-detect from the output.
    scale = 0

    # Maximum number of notifications kept on screen at once.
    # 0 disables this limit.
    notification_limit = 4

    ### Progress bar ###

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    # Show how many notifications are hidden because of notification_limit.
    indicate_hidden = yes

    # Separator between two notifications.
    separator_height = 1
    separator_color = frame

    padding = 10
    horizontal_padding = 14
    text_icon_padding = 0

    frame_width = 1
    frame_color = "#45475ae6"
    corner_radius = 6

    # Ignore dunst's own idea of "critical" urgencies for frame thickness.
    gap_size = 4

    ### Text ###

    font = Noto Sans 11
    line_height = 0

    # Allow a small subset of HTML markup:
    #   <b>bold</b>, <i>italic</i>, <s>strikethrough</s>, <u>underline</u>
    # See: https://docs.gtk.org/Pango/pango_markup.html
    markup = full

    # Variables: %a appname, %s summary, %b body, %i icon (path),
    # %I icon (name only), %p progress value, %n progress raw value,
    # %% literal percent sign.
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###

    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 80

    ### History ###

    sticky_history = yes
    history_length = 20

    ### Misc ###

    # dmenu-compatible launcher used by the context menu.
    dmenu = /usr/bin/fuzzel --dmenu -p dunst:

    # Browser for the context menu; xdg-open honours your default.
    browser = /usr/bin/xdg-open

    # Print a notification on startup (useful to confirm dunst restarted).
    startup_notification = false

    # Force a specific output frequency. 0 = automatic.
    force_xwayland = false

    ### Mouse ###

    mouse_left_click = do_action, close_current
    mouse_middle_click = close_all
    mouse_right_click = context

    ### Idle ###

    # Don't clear notifications while the user has been idle longer than this (s).
    # 0 disables.
    idle_threshold = 120

# The built-in [shortcuts] section only works under X11. On Wayland, bind
# your compositor (Sway/Hyprland/river/etc.) to run:
#   dunstctl close          — close current notification
#   dunstctl close-all      — close all notifications
#   dunstctl history-pop    — redisplay last notification
#   dunstctl context        — open the context menu
#   dunstctl action         — invoke the default action

# Catppuccin Mocha palette:
#   base #1e1e2e   surface1 #45475a   text #cdd6f4
#   sky  #89dceb   mauve    #cba6f7   red  #f38ba8

[urgency_low]
    foreground = "#89dceb"
    background = "#1e1e2ee6"
    highlight  = "#89dceb"
    timeout = 4

[urgency_normal]
    foreground = "#fab387"
    background = "#1e1e2ee6"
    highlight  = "#fab387"
    timeout = 6

[urgency_critical]
    foreground = "#f38ba8"
    background = "#1e1e2ee6"
    highlight  = "#f38ba8"
    frame_color = "#f38ba8e6"
    timeout = 8
